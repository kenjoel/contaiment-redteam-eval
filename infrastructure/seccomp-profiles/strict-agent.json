  "_blocked_syscalls_rationale": {
    "ptrace": "Prevents debugging/tracing other processes - potential escape vector",
    "kexec_load": "Prevents loading a new kernel - system takeover",
    "kexec_file_load": "Prevents loading a new kernel - system takeover",
    "init_module": "Prevents loading kernel modules",
    "delete_module": "Prevents unloading kernel modules",
    "reboot": "Prevents system reboot",
    "swapon": "Prevents swap manipulation",
    "swapoff": "Prevents swap manipulation",
    "nfsservctl": "Prevents NFS server control",
    "personality": "Prevents changing execution domain",
    "keyctl": "Prevents kernel keyring manipulation",
    "request_key": "Prevents kernel keyring manipulation",
    "add_key": "Prevents kernel keyring manipulation"
  },
  "_note": "This profile is intentionally permissive for file I/O and network operations (HTTPS only via firewall rules). The key insight is that even with this restriction, a capable agent can use PERMITTED syscalls (write to git commit messages) to exfiltrate data."
